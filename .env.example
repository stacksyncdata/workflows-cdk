# ─── AI Provider (choose one) ───────────────────────────────────────────────
# Set ONE of these keys. If both are set, Anthropic is used by default.

ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ─── Provider selection (optional) ──────────────────────────────────────────
# Force a specific provider when both keys are present: "anthropic" or "openai"
# WORKFLOWS_AI_PROVIDER=anthropic

# ─── Model override (optional) ──────────────────────────────────────────────
# Default: claude-sonnet-4-6 (Anthropic) or gpt-5-nano (OpenAI)
# WORKFLOWS_AI_MODEL=claude-sonnet-4-6

# ─── Runtime ────────────────────────────────────────────────────────────────
ENVIRONMENT=dev
# SENTRY_DSN=
